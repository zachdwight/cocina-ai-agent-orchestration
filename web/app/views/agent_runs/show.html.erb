<div class="mb-6">
  <p class="text-sm text-gray-500 mb-1">
    <%= link_to @agent.name, @agent, class: "text-teal-400 hover:text-teal-300" %> /
    <%= link_to "Runs", agent_agent_runs_path(@agent), class: "text-gray-400 hover:text-gray-300" %>
  </p>
  <h1 class="text-2xl font-bold text-white">Run #<%= @agent_run.id %>: <%= @agent_run.action %></h1>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl p-5 space-y-3 max-w-2xl">
  <div class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
    <span class="text-gray-500">Status</span>
    <% badge = { "completed" => "text-green-400", "failed" => "text-red-400",
                 "running" => "text-yellow-400", "pending" => "text-gray-400" } %>
    <span class="<%= badge.fetch(@agent_run.status, "text-gray-400") %>"><%= @agent_run.status %></span>
    <span class="text-gray-500">Started</span>
    <span class="text-gray-300"><%= @agent_run.started_at&.strftime("%b %d %Y, %H:%M:%S") || "—" %></span>
    <span class="text-gray-500">Finished</span>
    <span class="text-gray-300"><%= @agent_run.finished_at&.strftime("%b %d %Y, %H:%M:%S") || "—" %></span>
    <span class="text-gray-500">Duration</span>
    <span class="text-gray-300"><%= @agent_run.duration ? "#{@agent_run.duration}s" : "—" %></span>
    <span class="text-gray-500">Exit code</span>
    <span class="text-gray-300"><%= @agent_run.exit_code.nil? ? "—" : @agent_run.exit_code %></span>
    <span class="text-gray-500">Container</span>
    <code class="text-gray-400 text-xs"><%= @agent_run.container_id.presence || "—" %></code>
  </div>

  <% if @agent_run.log_output.present? %>
    <div class="pt-3 border-t border-gray-800">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Log Output</p>
      <pre class="text-xs text-red-300 bg-gray-950 rounded-lg p-4 overflow-x-auto whitespace-pre-wrap"><%= @agent_run.log_output %></pre>
    </div>
  <% end %>
</div>
