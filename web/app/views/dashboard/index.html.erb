<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-white">Kitchen Dashboard</h1>
    <p class="text-sm text-gray-500 mt-1">
      <%= @agents.count %> agents &mdash;
      <%= @agents.count(&:running?) %> running
    </p>
  </div>
  <%= link_to "New Agent", new_agent_path,
        class: "px-4 py-2 bg-teal-600 hover:bg-teal-500 text-white text-sm font-medium rounded-lg transition" %>
</div>

<% if @agents.any? %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
    <% @agents.each do |agent| %>
      <%= turbo_stream_from "agent_#{agent.id}" %>
      <%= render "agents/agent_card", agent: agent %>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-20 text-gray-600">
    <p class="text-lg mb-3">No agents yet.</p>
    <%= link_to "Create your first agent", new_agent_path, class: "text-teal-400 hover:text-teal-300 underline" %>
  </div>
<% end %>

<% if @recent_runs.any? %>
  <h2 class="text-lg font-semibold text-white mb-4">Recent Activity</h2>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-800 text-gray-400 text-xs uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Agent</th>
          <th class="px-4 py-3 text-left">Action</th>
          <th class="px-4 py-3 text-left">Status</th>
          <th class="px-4 py-3 text-left">When</th>
          <th class="px-4 py-3 text-left">Duration</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <% @recent_runs.each do |run| %>
          <tr class="hover:bg-gray-800/50 transition">
            <td class="px-4 py-3">
              <%= link_to run.agent.name, run.agent, class: "text-teal-400 hover:text-teal-300" %>
            </td>
            <td class="px-4 py-3 text-gray-300"><%= run.action %></td>
            <td class="px-4 py-3">
              <% badge = { "completed" => "text-green-400", "failed" => "text-red-400",
                           "running" => "text-yellow-400", "pending" => "text-gray-400" } %>
              <span class="<%= badge.fetch(run.status, "text-gray-400") %>"><%= run.status %></span>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs">
              <%= time_ago_in_words(run.created_at) %> ago
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs">
              <%= run.duration ? "#{run.duration}s" : "—" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
