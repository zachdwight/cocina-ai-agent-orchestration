<div class="bg-gray-900 border border-gray-800 rounded-xl p-5 flex flex-col gap-3">
  <div class="flex items-start justify-between gap-2">
    <div>
      <%= link_to agent.name, agent, class: "text-base font-semibold text-white hover:text-teal-400 transition" %>
      <p class="text-xs text-gray-500 mt-0.5"><%= agent.description.presence || agent.image %></p>
    </div>
    <div id="agent_status_<%= agent.id %>">
      <%= render "agents/status_badge", agent: agent %>
    </div>
  </div>

  <code class="text-xs text-gray-400 bg-gray-800 rounded px-2 py-1 block truncate">
    <%= agent.image %>
  </code>

  <div class="flex gap-2 mt-1">
    <%= button_to "Start", start_agent_path(agent), method: :post,
          class: "flex-1 text-xs px-3 py-1.5 rounded-lg font-medium transition
                  #{ agent.running? || agent.pending? ? 'bg-gray-700 text-gray-500 cursor-not-allowed' : 'bg-teal-600 hover:bg-teal-500 text-white' }",
          disabled: agent.running? || agent.pending?,
          data: { turbo_stream: true } %>
    <%= button_to "Stop", stop_agent_path(agent), method: :post,
          class: "flex-1 text-xs px-3 py-1.5 rounded-lg font-medium transition
                  #{ !agent.running? ? 'bg-gray-700 text-gray-500 cursor-not-allowed' : 'bg-red-700 hover:bg-red-600 text-white' }",
          disabled: !agent.running?,
          data: { turbo_stream: true } %>
    <%= link_to "Detail", agent,
          class: "text-xs px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 transition text-center" %>
  </div>
</div>
