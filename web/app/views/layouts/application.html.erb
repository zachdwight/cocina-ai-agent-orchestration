<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Cocina — AI Agent Kitchen</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen font-sans">

  <nav class="bg-gray-900 border-b border-gray-800 px-6 py-3 flex items-center gap-6">
    <%= link_to "🍳 Cocina", root_path, class: "text-lg font-bold text-white tracking-tight" %>
    <%= link_to "Dashboard", root_path,    class: "text-sm text-gray-400 hover:text-white transition" %>
    <%= link_to "Agents",    agents_path,  class: "text-sm text-gray-400 hover:text-white transition" %>
    <span class="ml-auto text-xs text-gray-600">AI Agent Kitchen</span>
  </nav>

  <main class="max-w-7xl mx-auto px-6 py-8">
    <% flash.each do |type, msg| %>
      <div class="mb-4 px-4 py-3 rounded-lg text-sm
        <%= type == 'notice' ? 'bg-teal-900 text-teal-200 border border-teal-700' : 'bg-red-900 text-red-200 border border-red-700' %>">
        <%= msg %>
      </div>
    <% end %>
    <%= yield %>
  </main>

</body>
</html>
